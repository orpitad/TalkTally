# Copy to .env and set the correct IP for your dev machine.
#
# Android emulator  → use 10.0.2.2 (emulator's alias for your localhost)
# iOS simulator     → use localhost
# Real device       → use your machine's local IP (e.g. 192.168.1.42)
#
# The EXPO_PUBLIC_ prefix makes this variable available in JS via process.env

EXPO_PUBLIC_API_URL=http://192.168.10.46:3000